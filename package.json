{
  "name": "yarn-inspiration",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && node_modules\\electron\\dist\\electron.exe .\"",
    "electron:build": "npm run build && node scripts/copy-standalone.js && electron-builder --win",
    "electron:build:linux": "npm run build && node scripts/copy-standalone.js && electron-builder --linux",
    "electron:build:mac": "npm run build && node scripts/copy-standalone.js && electron-builder --mac"
  },
  "build": {
    "appId": "com.yarninspiration.app",
    "productName": "YarnInspire",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "data/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "node-html-parser": "^7.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sql.js": "^1.10.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "wait-on": "^9.0.10"
  }
}
